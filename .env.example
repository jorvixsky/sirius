# Sirius / OpenClaw workspace environment example
# Copy to .env or export these variables in the runtime environment.
# Never commit real secrets in this file.

# Email account used by Sirius for SMTP/IMAP
# Preferred: set SIRIUS_EMAIL_PASSWORD in the service environment.
# Fallback supported by cron_email_monitor.sh:
#   /home/sirius/.openclaw/secrets/sirius_email_password
SIRIUS_EMAIL=sirius@jordiplanas.cat
SIRIUS_EMAIL_PASSWORD=replace-with-email-password
SIRIUS_IMAP_SERVER=mail.jordiplanas.cat
SIRIUS_IMAP_PORT=993
SIRIUS_SMTP_SERVER=smtp.jordiplanas.cat
SIRIUS_SMTP_PORT=587

# Jordi must always be Bcc'd on emails Sirius sends
SIRIUS_DEFAULT_BCC=hola@jordiplanas.cat

# OpenRouter credit monitoring
# Preferred: set this environment variable in the service environment.
# Fallback supported by cron_openrouter_monitor.sh:
#   /home/sirius/.openclaw/secrets/openrouter_management_key
OPENROUTER_MANAGEMENT_KEY=replace-with-openrouter-management-key
OPENROUTER_MIN_BALANCE=5.0
OPENROUTER_SUGGESTED_ADD_AMOUNT=20.0
OPENROUTER_LOW_REMINDER_HOURS=24

# CreditClaw / payment tooling, if enabled
CREDITCLAW_API_KEY=cck_live_replace-with-key

# Optional: override CLI paths used by cron_auto_update.sh
OPENCLAW_BIN=/home/sirius/.npm-global/bin/openclaw
CLAWHUB_BIN=/home/sirius/.local/bin/clawhub
